{
  "name": "@mahama/lordina-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/main.js",
    "seed": "tsx --env-file=.env src/seed/run-seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo skip",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mahama/backend-core": "workspace:*",
    "@mahama/config": "workspace:*",
    "@mahama/jwt-utils": "workspace:*",
    "@mahama/shared-types": "workspace:*",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "inversify": "^7.5.1",
    "mongodb": "^6.12.0",
    "openai": "^4.78.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
